<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.kahya.kahyad</string>
	<key>ProgramArguments</key>
	<array>
		<string>__KAHYA_REPO_ROOT__/bin/kahyad</string>
	</array>
	<key>KeepAlive</key>
	<true/>
	<key>RunAtLoad</key>
	<true/>
	<key>StandardOutPath</key>
	<string>__KAHYA_LOG_DIR__/launchd-kahyad.out.log</string>
	<key>StandardErrorPath</key>
	<string>__KAHYA_LOG_DIR__/launchd-kahyad.err.log</string>
</dict>
</plist>
